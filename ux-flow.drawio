                <mxCell id="welcome" value="&lt;div style=&quot;font-size:12px;font-weight:700;color:#00918c;&quot;&gt;STEP 1&lt;/div&gt;&lt;div style=&quot;font-size:24px;font-weight:700;margin-top:8px;&quot;&gt;Welcome&lt;/div&gt;&lt;div style=&quot;margin-top:8px;color:#6d7a88;&quot;&gt;Entry screen explaining that a TwoNav account is required before redeeming free products.&lt;/div&gt;&lt;hr&gt;&lt;b&gt;File:&lt;/b&gt; index.html&lt;br&gt;&lt;b&gt;Exits:&lt;/b&gt; create account or existing account login" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8e2ea;fontColor=#23364a;shadow=1;spacing=14;" parent="1" vertex="1">
                    <mxGeometry x="70" y="470" width="290" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="signin" value="&lt;div style=&quot;font-size:12px;font-weight:700;color:#00918c;&quot;&gt;STEP 2A&lt;/div&gt;&lt;div style=&quot;font-size:24px;font-weight:700;margin-top:8px;&quot;&gt;Login to TwoNav&lt;/div&gt;&lt;div style=&quot;margin-top:8px;color:#6d7a88;&quot;&gt;Existing user enters email and password, then submits the form to the promo-code screen.&lt;/div&gt;&lt;hr&gt;&lt;b&gt;File:&lt;/b&gt; signin.html&lt;br&gt;&lt;b&gt;Submit:&lt;/b&gt; promocode.html&lt;br&gt;&lt;b&gt;Back:&lt;/b&gt; index.html" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8e2ea;fontColor=#23364a;shadow=1;spacing=14;" parent="1" vertex="1">
                    <mxGeometry x="420" y="320" width="290" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="register" value="&lt;div style=&quot;font-size:12px;font-weight:700;color:#00918c;&quot;&gt;STEP 2B&lt;/div&gt;&lt;div style=&quot;font-size:24px;font-weight:700;margin-top:8px;&quot;&gt;Create Account&lt;/div&gt;&lt;div style=&quot;margin-top:8px;color:#6d7a88;&quot;&gt;New user creates a TwoNav account, then submits the form to continue redeeming the code.&lt;/div&gt;&lt;hr&gt;&lt;b&gt;File:&lt;/b&gt; register.html&lt;br&gt;&lt;b&gt;Submit:&lt;/b&gt; promocode.html&lt;br&gt;&lt;b&gt;Back:&lt;/b&gt; index.html" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#d8e2ea;fontColor=#23364a;shadow=1;spacing=14;" parent="1" vertex="1">
